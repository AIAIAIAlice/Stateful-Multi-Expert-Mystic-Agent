# === MiMo LLM API ===
MIMO_API_KEY=
MIMO_OPENAI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_DEFAULT_MODEL=mimo-v2.5-pro
MIMO_LIGHT_MODEL=mimo-v2.5
USE_MOCK_LLM=true

# === Embedding API (DashScope) ===
# Used by ChromaDB vector retrieval. The default model is text-embedding-v2.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v2

# === ChromaDB ===
# Use a local path outside the repository for private/generated vector stores.
CHROMA_DIR=./data/chroma_db

# === Jina Reranker ===
JINA_API_KEY=
JINA_RERANKER_MODEL=jina-reranker-v2-base-multilingual
JINA_RERANKER_URL=https://api.jina.ai/v1/rerank

# === LangSmith Tracing ===
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=yhj-agent
